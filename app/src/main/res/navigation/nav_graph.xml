<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/startFragment">

    <action
        android:id="@+id/action_global_password"
        app:destination="@id/password"
        app:enterAnim="@anim/fade_in_fast"
        app:exitAnim="@anim/fade_out_fast"
        app:popEnterAnim="@anim/fade_in_fast"
        app:popExitAnim="@anim/fade_out_fast" />

    <fragment
        android:id="@+id/startFragment"
        android:name="se.arctosoft.vault.StartFragment"
        android:label=""
        tools:layout="@layout/fragment_start">
        <action
            android:id="@+id/action_start_to_password"
            app:destination="@id/password"
            app:enterAnim="@anim/fade_in_fast"
            app:exitAnim="@anim/fade_out_fast" />
    </fragment>

    <fragment
        android:id="@+id/directory"
        android:name="se.arctosoft.vault.DirectoryFragment"
        android:label="@string/gallery_title"
        tools:layout="@layout/fragment_directory">
        <action
            android:id="@+id/action_directory_to_settings"
            app:destination="@id/settings" />
        <action
            android:id="@+id/action_directory_self"
            app:destination="@id/directory">
            <argument
                android:name="directory"
                app:argType="string"
                app:nullable="false" />
            <argument
                android:name="nestedPath"
                app:argType="string"
                app:nullable="true" />
        </action>
        <action
            android:id="@+id/action_directory_to_directory_all"
            app:destination="@id/directory_all" />
    </fragment>

    <fragment
        android:id="@+id/directory_all"
        android:name="se.arctosoft.vault.DirectoryAllFragment"
        android:label="@string/gallery_all"
        tools:layout="@layout/fragment_directory">
        <action
            android:id="@+id/action_directory_to_settings"
            app:destination="@id/settings" />
    </fragment>

    <fragment
        android:id="@+id/password"
        android:name="se.arctosoft.vault.PasswordFragment"
        android:label="@string/launcher_title"
        tools:layout="@layout/fragment_password">
        <argument
            android:name="is_create_mode"
            android:defaultValue="false"
            app:argType="boolean" />
        
        <action
            android:id="@+id/action_password_to_directory"
            app:destination="@id/directory"
            app:popUpTo="@id/startFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/settings"
        android:name="se.arctosoft.vault.SettingsFragment"
        android:label="@string/settings" />

</navigation>
