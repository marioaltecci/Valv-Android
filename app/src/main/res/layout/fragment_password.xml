<?xml version="1.0" encoding="utf-8"?>
<!-- 
  Русский: Корневой элемент макета - ConstraintLayout (гибкий компоновщик ограничений) от AndroidX.
  Английский: Root layout element - AndroidX ConstraintLayout (flexible constraint-based layout).
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"        <!-- Рус: Фон из темы (поверхность). Англ: Theme background (surface color). -->
    android:fitsSystemWindows="true"               <!-- Рус: Учитывать системные панели (статус-бар и навигацию). Англ: Fit system windows (status/nav bars). -->
    tools:context=".PasswordFragment">             <!-- Рус: Привязка к фрагменту PasswordFragment в IDE. Англ: Links to PasswordFragment in IDE preview. -->

    <!-- 
      Рус: ScrollView - позволяет прокручивать контент, если он не помещается по высоте.
      Англ: ScrollView - makes content scrollable if taller than screen.
    -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"                <!-- Рус: Высота будет задана ограничениями (0dp = match constraints). Англ: Height determined by constraints (0dp = match constraints). -->
        android:scrollbars="none"                  <!-- Рус: Скрыть полосы прокрутки. Англ: Hide scrollbars. -->
        android:overScrollMode="always"            <!-- Рус: Всегда показывать эффект "натяжения" при прокрутке до края. Англ: Always show overscroll (glow) effect. -->
        android:fillViewport="false"               <!-- Рус: Не растягивать содержимое на весь viewport, если оно маленькое. Англ: Don't stretch content to full viewport height if small. -->
        app:layout_constraintBottom_toTopOf="@id/btnHelp"  <!-- Рус: Нижний край привязан к верхней кнопки "Помощь". Англ: Bottom edge constrained to top of Help button. -->
        app:layout_constraintTop_toTopOf="parent">         <!-- Рус: Верхний край привязан к верху родителя. Англ: Top edge constrained to parent's top. -->

        <!-- 
          Рус: LinearLayout - вертикальное расположение элементов внутри ScrollView.
          Англ: LinearLayout - vertical arrangement inside ScrollView.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"    <!-- Рус: Горизонтальное центрирование дочерних элементов. Англ: Horizontally center children. -->
            android:orientation="vertical"          <!-- Рус: Элементы идут сверху вниз. Англ: Items flow top to bottom. -->
            android:padding="24dp">                 <!-- Рус: Отступы от краёв 24dp. Англ: 24dp padding from edges. -->

            <!-- 
              Рус: FrameLayout - контейнер для логотипа (чтобы добавить кликабельность).
              Англ: FrameLayout - container for logo (to add clickability).
            -->
            <FrameLayout
                android:id="@+id/logo_container"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="60dp"     <!-- Рус: Отступ сверху 60dp. Англ: Top margin 60dp. -->
                android:background="@android:color/transparent"  <!-- Рус: Прозрачный фон. Англ: Transparent background. -->
                android:clickable="true"            <!-- Рус: Можно нажимать. Англ: Clickable. -->
                android:focusable="true">           <!-- Рус: Может получать фокус. Англ: Focusable. -->

                <!-- 
                  Рус: ImageView - отображает логотип из drawable.
                  Англ: ImageView - displays logo from drawable.
                -->
                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="22dp"          <!-- Рус: Внутренний отступ 22dp. Англ: Inner padding 22dp. -->
                    android:translationY="5dp"      <!-- Рус: Сдвиг вниз на 5dp (визуальный эффект). Англ: Shift down 5dp (visual effect). -->
                    android:scaleType="fitCenter"   <!-- Рус: Масштабировать, сохраняя пропорции, по центру. Англ: Scale keeping aspect ratio, centered. -->
                    android:src="@drawable/logo"    <!-- Рус: Ресурс логотипа. Англ: Logo drawable resource. -->
                    android:contentDescription="@null"  <!-- Рус: Нет текстового описания (декоративный элемент). Англ: No content description (decorative). -->
                    app:tint="?attr/colorOnSurface" />  <!-- Рус: Цветовая тонировка из темы (на поверхности). Англ: Theme tint color (on surface). -->
            </FrameLayout>

            <!-- 
              Рус: TextView - заголовок экрана.
              Англ: TextView - screen title.
            -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/launcher_title"      <!-- Рус: Текст из ресурсов. Англ: Text from string resources. -->
                android:textAlignment="center"             <!-- Рус: Выравнивание по центру. Англ: Center alignment. -->
                android:textColor="?attr/colorOnSurface"   <!-- Рус: Цвет текста из темы. Англ: Text color from theme. -->
                android:textSize="24sp"                    <!-- Рус: Размер шрифта 24sp. Англ: Font size 24sp. -->
                android:textStyle="bold" />                <!-- Рус: Жирное начертание. Англ: Bold style. -->

            <!-- 
              Рус: TextView - подзаголовок экрана.
              Англ: TextView - screen subtitle.
            -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/launcher_subtitle"   <!-- Рус: Текст подзаголовка из ресурсов. Англ: Subtitle text from resources. -->
                android:textAlignment="center"
                android:textColor="?android:attr/textColorSecondary" /> <!-- Рус: Вторичный цвет текста системы. Англ: System secondary text color. -->

            <!-- 
              Рус: TextInputLayout - обёртка для поля ввода пароля (Material Design).
              Англ: TextInputLayout - wrapper for password input field (Material Design).
            -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textField"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"  <!-- Рус: Стиль "заполненная коробка", плотный. Англ: Filled box dense style. -->
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:boxBackgroundColor="?attr/colorSurfaceVariant"  <!-- Рус: Цвет фона поля из темы. Англ: Box background from theme. -->
                app:boxCornerRadiusBottomEnd="20dp"                 <!-- Рус: Скругление углов 20dp. Англ: Corner radius 20dp. -->
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeWidth="0dp"                            <!-- Рус: Нет обводки. Англ: No stroke width. -->
                app:boxStrokeWidthFocused="0dp"                     <!-- Рус: Нет обводки при фокусе. Англ: No stroke when focused. -->
                app:endIconMode="password_toggle"                   <!-- Рус: Иконка в конце - переключение видимости пароля. Англ: End icon - password visibility toggle. -->
                app:endIconTint="?android:attr/textColorSecondary"  <!-- Рус: Цвет иконки - вторичный. Англ: Icon color - secondary. -->
                app:hintEnabled="false"                             <!-- Рус: Отключить плавающую подсказку. Англ: Disable floating hint. -->
                app:counterEnabled="true"                           <!-- Рус: Показывать счётчик символов. Англ: Show character counter. -->
                app:counterMaxLength="60"                           <!-- Рус: Максимальная длина 60 символов. Англ: Max length 60 chars. -->
                app:errorEnabled="false">                           <!-- Рус: Отключить отображение ошибок. Англ: Disable error display. -->

                <!-- 
                  Рус: TextInputEditText - само поле ввода пароля.
                  Англ: TextInputEditText - actual password input field.
                -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/eTPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/launcher_password_hint"   <!-- Рус: Подсказка из ресурсов. Англ: Hint from resources. -->
                    android:inputType="textPassword"               <!-- Рус: Тип ввода - пароль (точки вместо символов). Англ: Input type - password (dots instead of chars). -->
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?android:attr/textColorHint"  <!-- Рус: Цвет подсказки системный. Англ: Hint color - system default. -->
                    android:gravity="start|center_vertical"        <!-- Рус: Текст по левому краю, вертикально по центру. Англ: Text start aligned, vertically centered. -->
                    android:paddingStart="24dp"                    <!-- Рус: Отступ слева 24dp. Англ: Left padding 24dp. -->
                    android:paddingEnd="48dp"                      <!-- Рус: Отступ справа 48dp (место под иконку). Англ: Right padding 48dp (space for icon). -->
                    android:paddingVertical="18dp"                 <!-- Рус: Вертикальные отступы 18dp. Англ: Vertical padding 18dp. -->
                    android:maxLength="80" />                      <!-- Рус: Максимум 80 символов (перекрывает counterMaxLength). Англ: Max 80 chars (overrides counterMaxLength). -->
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 
              Рус: ConstraintLayout - контейнер для кнопок и индикатора загрузки (расположение в один ряд).
              Англ: ConstraintLayout - container for buttons and loading indicator (horizontal arrangement).
            -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <!-- 
                  Рус: MaterialButton - кнопка биометрии (отпечаток пальца/лицо).
                  Англ: MaterialButton - biometrics button (fingerprint/face).
                -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/biometrics"
                    style="@style/Widget.Material3.Button.IconButton"  <!-- Рус: Стиль - иконка без текста. Англ: Icon button style without text. -->
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:icon="@drawable/rounded_fingerprint_24"       <!-- Рус: Иконка отпечатка пальца. Англ: Fingerprint icon. -->
                    app:iconSize="32dp"                               <!-- Рус: Размер иконки 32dp. Англ: Icon size 32dp. -->
                    app:iconTint="?attr/colorPrimary"                 <!-- Рус: Цвет иконки - основной из темы. Англ: Icon color - primary theme color. -->
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- 
                  Рус: CircularProgressIndicator - круговой индикатор загрузки.
                  Англ: CircularProgressIndicator - circular loading spinner.
                -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"                      <!-- Рус: Бесконечная анимация (неопределённый режим). Англ: Indeterminate mode (continuous animation). -->
                    android:visibility="gone"                         <!-- Рус: По умолчанию скрыт. Англ: Hidden by default. -->
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnUnlock"  <!-- Рус: Справа от кнопки btnUnlock. Англ: To the left of btnUnlock. -->
                    app:layout_constraintTop_toTopOf="parent"
                    app:indicatorSize="24dp" />                       <!-- Рус: Размер индикатора 24dp. Англ: Indicator size 24dp. -->

                <!-- 
                  Рус: MaterialButton - главная кнопка "Разблокировать".
                  Англ: MaterialButton - main "Unlock" button.
                -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnlock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"                          <!-- Рус: Минимальная высота 56dp. Англ: Min height 56dp. -->
                    android:enabled="false"                           <!-- Рус: По умолчанию отключена (пока не введён пароль). Англ: Disabled by default (until password entered). -->
                    android:text="@string/launcher_button"            <!-- Рус: Текст из ресурсов. Англ: Text from resources. -->
                    app:cornerRadius="28dp"                           <!-- Рус: Скругление углов 28dp. Англ: Corner radius 28dp. -->
                    app:layout_constraintEnd_toEndOf="parent"         <!-- Рус: Привязана к правому краю родителя. Англ: Constrained to parent's right edge. -->
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 
      Рус: MaterialButton - кнопка "Помощь" в левом нижнем углу (текстовая кнопка).
      Англ: MaterialButton - "Help" button in bottom-left corner (text button).
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHelp"
        style="@style/Widget.Material3.Button.TextButton"   <!-- Рус: Стиль текстовой кнопки (без фона). Англ: Text button style (no background). -->
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"                   <!-- Рус: Отступ слева 16dp. Англ: Left margin 16dp. -->
        android:layout_marginBottom="16dp"                  <!-- Рус: Отступ снизу 16dp. Англ: Bottom margin 16dp. -->
        android:text="@string/help"                         <!-- Рус: Текст из ресурсов. Англ: Text from resources. -->
        app:icon="@drawable/ic_outline_tips_and_updates_24" <!-- Рус: Иконка "подсказки/обновления". Англ: Tips/updates icon. -->
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
