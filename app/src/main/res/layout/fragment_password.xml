<?xml version="1.0" encoding="utf-8"?>
<!--
  EN: Password fragment layout – screen for entering password / biometrics
  RU: Макет фрагмента ввода пароля – экран для ввода пароля / биометрии
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    tools:context=".PasswordFragment">

    <!--
      EN: Scrollable content block – allows scrolling when keyboard appears
      RU: Блок с прокруткой – позволяет скроллить при появлении клавиатуры
    -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="always"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintTop_toTopOf="parent">

        <!--
          EN: Main content container – vertical arrangement of elements
          RU: Контейнер основного контента – вертикальное расположение элементов
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!--
              EN: Logo block with clickable container
              RU: Блок логотипа с кликабельным контейнером
            -->
            <FrameLayout
                android:id="@+id/logo_container"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="60dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <!-- EN: Application logo image | RU: Изображение логотипа приложения -->
                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="22dp"
                    android:translationY="5dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo"
                    android:contentDescription="@null"
                    app:tint="?attr/colorOnSurface" />
            </FrameLayout>

            <!-- EN: Main title (app name) | RU: Главный заголовок (название приложения) -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/launcher_title"
                android:textAlignment="center"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- EN: Subtitle (additional info) | RU: Подзаголовок (дополнительная информация) -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/launcher_subtitle"
                android:textAlignment="center"
                android:textColor="?android:attr/textColorSecondary" />

            <!--
              EN: Password input field block with custom styling
              RU: Блок поля ввода пароля с пользовательской стилизацией
            -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textField"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:boxBackgroundColor="?attr/colorSurfaceVariant"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:endIconMode="password_toggle"
                app:endIconTint="?android:attr/textColorSecondary"
                app:hintEnabled="false"
                app:counterEnabled="false"
                app:counterMaxLength="60">

                <!-- EN: Editable password field | RU: Редактируемое поле для пароля -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/eTPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/launcher_password_hint"
                    android:inputType="textPassword"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingStart="24dp"
                    android:paddingEnd="48dp"
                    android:paddingVertical="18dp"
                    android:maxLength="80" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--
              EN: Custom character counter – positioned to the right under the eye icon
              RU: Пользовательский счётчик символов – расположен справа под иконкой глаза
            -->
            <TextView
                android:id="@+id/tvCharCounter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="12dp"
                android:gravity="end"
                android:text="0/60"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp" />

            <!--
              EN: Biometric authentication button (fingerprint)
              RU: Кнопка биометрической аутентификации (отпечаток пальца)
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/biometrics"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                app:icon="@drawable/rounded_fingerprint_24"
                app:iconSize="32dp"
                app:iconTint="?attr/colorPrimary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!--
      EN: Bottom fixed container – buttons and loading indicator
      RU: Нижний фиксированный контейнер – кнопки и индикатор загрузки
    -->
    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- EN: Loading spinner (hidden by default) | RU: Индикатор загрузки (скрыт по умолчанию) -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorSize="28dp" />

        <!--
          EN: Unlock button (disabled by default, appears after entering password)
          RU: Кнопка разблокировки (отключена по умолчанию, появляется после ввода пароля)
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnlock"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:enabled="false"
            android:text="@string/launcher_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="32dp"
            tools:visibility="visible" />

        <!--
          EN: Help button (text style, left-aligned, with icon)
          RU: Кнопка помощи (текстовый стиль, выравнивание по левому краю, с иконкой)
        -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHelp"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="8dp"
            android:text="@string/help"
            app:icon="@drawable/ic_outline_tips_and_updates_24"
            app:iconTint="?android:attr/textColorSecondary" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
